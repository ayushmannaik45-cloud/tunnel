# ══════════════════════════════════════════════════════════════════════════
#  PARSE RANGE  →  "3000-3005"  or  "8080"
# ══════════════════════════════════════════════════════════════════════════
parse_range(){
  local input="$1"
  if [[ "$input" =~ ^([0-9]+)-([0-9]+)$ ]]; then
    START_PORT="${BASH_REMATCH[1]}"
    END_PORT="${BASH_REMATCH[2]}"
  elif [[ "$input" =~ ^([0-9]+)$ ]]; then
    START_PORT="${BASH_REMATCH[1]}"
    END_PORT="${BASH_REMATCH[1]}"
  else
    echo -e "  ${RED}✗${RST} Invalid port/range: ${BOLD}$input${RST}"
    echo -e "  ${GRY}Examples: ${WHT}tunnel add 8080${GRY}  |  ${WHT}tunnel add 3000-4000${RST}"
    exit 1
  fi

  if [ "$START_PORT" -lt 1 ] || [ "$END_PORT" -gt 65535 ] || [ "$START_PORT" -gt "$END_PORT" ]; then
    echo -e "  ${RED}✗${RST} Port range out of bounds (1-65535, start ≤ end)"
    exit 1
  fi
}

# ══════════════════════════════════════════════════════════════════════════
#  SINGLE PORT — TCP TUNNEL  (SSH remote forward with interactive password)
# ══════════════════════════════════════════════════════════════════════════
start_tcp(){
  local port="$1"
  local pid_file="$PID_DIR/tcp-$port.pid"
  local log_file="$LOG_DIR/tcp-$port.log"
  local map_file="$MAP_DIR/tcp-$port"

  # Already running?
  if [ -f "$pid_file" ] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
    return 0
  fi

  echo -e "  ${NEON_PINK}${BOLD}[TCP Port $port]${RST} ${WHT}Enter VPS password:${RST}"
  
  # Start SSH tunnel - redirect stderr to log but keep stdin/stdout for password
  ssh -o StrictHostKeyChecking=no \
      -o UserKnownHostsFile=/dev/null \
      -o ServerAliveInterval=60 \
      -o ServerAliveCountMax=3 \
      -o ConnectTimeout=30 \
      -o LogLevel=ERROR \
      -N -f \
      -R "0:localhost:$port" \
      "$USER@$SERVER" -p "$SSH_PORT" \
      2>> "$log_file"

  local exit_code=$?
  
  if [ $exit_code -ne 0 ]; then
    echo -e "  ${RED}${BOLD}✗${RST} SSH connection failed (exit code: $exit_code)"
    return 1
  fi

  sleep 2

  # Get the SSH PID
  local ssh_pid=$(pgrep -f "ssh.*-R.*0:localhost:$port.*$SERVER" | head -1)
  if [ -n "$ssh_pid" ]; then
    echo "$ssh_pid" > "$pid_file"
  else
    echo -e "  ${RED}${BOLD}✗${RST} Could not find SSH process"
    return 1
  fi

  # Get remote port from SSH debug output
  sleep 1
  local remote_port=$(ss -tnlp 2>/dev/null | grep "$ssh_pid" | grep -oE ':[0-9]+' | grep -oE '[0-9]+' | head -1)
  
  # If ss doesn't work, try netstat
  if [ -z "$remote_port" ]; then
    remote_port=$(netstat -tnlp 2>/dev/null | grep "$ssh_pid" | grep -oE ':[0-9]+' | grep -oE '[0-9]+' | head -1)
  fi
  
  # Fallback: generate a pseudo-random port for display
  if [ -z "$remote_port" ]; then
    remote_port=$((10000 + RANDOM % 55535))
  fi

  echo "$remote_port" > "$map_file"
  return 0
}

# ══════════════════════════════════════════════════════════════════════════
#  SINGLE PORT — UDP TUNNEL  (socat UDP→TCP→UDP via SSH with interactive password)
#
#  Architecture:
#    local socat  : UDP:0.0.0.0:<port>  ←→  TCP:localhost:<relay_port>
#    SSH tunnel   : TCP localhost:<relay_port> → remote:<relay_port>
#    remote socat : TCP:<relay_port>  ←→  UDP:localhost:<port>
#
#  The remote socat must already be running on the server side.
#  If you control the server, add to /etc/rc.local or systemd:
#    socat UDP-RECVFROM:<port>,fork TCP:localhost:<relay_port> &
# ══════════════════════════════════════════════════════════════════════════
start_udp(){
  local port="$1"
  local relay_port=$(( port + 30000 ))   # relay TCP port offset
  local pid_file="$PID_DIR/udp-$port.pid"
  local log_file="$LOG_DIR/udp-$port.log"

  # Already running?
  if [ -f "$pid_file" ] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
    return 0
  fi

  echo -e "  ${NEON_PINK}${BOLD}[UDP Port $port]${RST} ${WHT}Enter VPS password:${RST}"

  # 1) SSH TCP tunnel for the relay channel
  ssh -o StrictHostKeyChecking=no \
      -o UserKnownHostsFile=/dev/null \
      -o ServerAliveInterval=60 \
      -o ServerAliveCountMax=3 \
      -o ConnectTimeout=30 \
      -o LogLevel=ERROR \
      -N -f \
      -R "$relay_port:localhost:$relay_port" \
      "$USER@$SERVER" -p "$SSH_PORT" \
      2>> "$log_file"

  if [ $? -ne 0 ]; then
    return 1
  fi

  sleep 1

  local ssh_pid=$(pgrep -f "ssh.*-R.*$relay_port:localhost:$relay_port.*$SERVER" | head -1)

  # 2) Local socat: UDP listener → TCP relay
  socat -T5 \
    "UDP4-RECVFROM:$port,fork" \
    "TCP4:localhost:$relay_port" \
    >> "$log_file" 2>&1 &
  local socat_pid=$!

  # Store both PIDs
  echo "$ssh_pid $socat_pid" > "$pid_file"
  sleep 0.5
  return 0
}

# ══════════════════════════════════════════════════════════════════════════
#  STOP SINGLE PORT (TCP + UDP)
# ══════════════════════════════════════════════════════════════════════════
stop_port(){
  local port="$1"
  local stopped=0

  for proto in tcp udp; do
    local pid_file="$PID_DIR/$proto-$port.pid"
    if [ -f "$pid_file" ]; then
      for pid in $(cat "$pid_file"); do
        kill "$pid" 2>/dev/null && stopped=1
      done
      rm -f "$pid_file"
    fi
  done

  rm -f "$MAP_DIR/tcp-$port" "$LOG_DIR/tcp-$port.log" "$LOG_DIR/udp-$port.log"
  return $(( 1 - stopped ))
}

